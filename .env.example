# =========================================================================
# Suchit Nagar Nigam (ਸੁਚਿਤ ਨਗਰ ਨਿਗਮ) - Env Configuration Example
# =========================================================================

# --- FastAPI Backend Configuration ---
PORT=8000
HOST=0.0.0.0

# --- OCR Integration ---
# Register and retrieve API key from Mistral Console
MISTRAL_API_KEY=your_mistral_api_key_here

# --- Gemini AI Integration (Multi-Key Rotation) ---
# Paste up to 3 keys. The system rotates round-robin and handles 429 rate limit errors automatically.
GEMINI_API_KEY_1=your_first_gemini_api_key
GEMINI_API_KEY_2=your_second_gemini_api_key_optional
GEMINI_API_KEY_3=your_third_gemini_api_key_optional

# --- Supabase Database Integration (PostgreSQL Service) ---
# Retrieve URL and Keys from Supabase Dashboard (Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-for-admin-write-access

# --- Frontend Next.js Public environment variables ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anonymous-key
NEXT_PUBLIC_API_URL=http://localhost:8000
